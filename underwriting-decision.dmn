        <dmn:outputEntry id="_3906A783-D927-496E-9214-F899D541C64B">
          <dmn:text>&quot;Debt-to-income ratio exceeds 43% threshold&quot;</dmn:text>
        </dmn:outputEntry>
        <dmn:annotationEntry>
          <dmn:text></dmn:text>
        </dmn:annotationEntry>
      </dmn:rule>
      <dmn:rule id="_9E2EBD90-C527-4B0A-ABC7-2196E0F775D3">
        <dmn:inputEntry id="_64E4C395-DDD8-4190-AA4C-5C899B634105">
          <dmn:text>-</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="_152FFFAD-FF8C-4522-94D5-9FF10371AA61">
