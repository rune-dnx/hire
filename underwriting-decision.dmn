        </dmn:inputEntry>
        <dmn:inputEntry id="_D9AD6D1A-7AC1-4DD7-8B77-BA9230E3CC55">
          <dmn:text>-</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="_17300BB1-572D-4505-AD5F-6D86EF70B286">
          <dmn:text>-</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="_CEE0BB58-4CDA-424F-8363-A7A44068163A">
          <dmn:text>&quot;DENY&quot;</dmn:text>
        </dmn:outputEntry>
        <dmn:outputEntry id="_BBD1B741-4B64-462B-9301-347389BB887E">
