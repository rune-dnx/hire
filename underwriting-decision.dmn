  <dmn:decision id="_49E05A4F-CF3C-4F0B-9CBF-B1ED840F70E5" name="Monthly Payment Estimate">
    <dmn:extensionElements />
    <dmn:variable id="_DDABA657-F6D7-4534-9D12-83DDDD3E62AB" name="Monthly Payment Estimate" typeRef="number" />
    <dmn:informationRequirement id="_20C0928C-7291-4414-B5C4-5F59D8D131E8">
      <dmn:requiredInput href="#_FC133BE5-348C-48D8-8308-479456F905D6" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_3081D662-7A18-495D-9EDD-A6789A1FCAB2">
      <dmn:requiredInput href="#_792F25A0-FDEB-4AE9-B801-43FD945F16CF" />
    </dmn:informationRequirement>
    <dmn:literalExpression id="_6FA43A52-0BE2-4EB2-AF6A-C694E4FFFDF8">
      <dmn:text>(loanAmount - downPayment) * 0.006</dmn:text>
    </dmn:literalExpression>
  </dmn:decision>
  <dmn:decision id="_E88896B2-607C-470C-8931-406359CE18A7" name="Debt to Income Ratio">
    <dmn:extensionElements />
    <dmn:variable id="_5802D75E-8BF9-47B5-A94E-BAA9432F20F4" name="Debt to Income Ratio" typeRef="number" />
    <dmn:informationRequirement id="_AA318B21-ED8C-427D-AB08-2D47098786A1">
      <dmn:requiredInput href="#_E16B2168-DC27-4794-A32F-613674B18EBD" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_43AC3880-40F3-420A-84D5-F02BB55C0D2F">
      <dmn:requiredInput href="#_B8F5562E-DEAE-4A25-9D15-B0147076AC34" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_4FFD6F0D-308D-4FE5-A8F0-EBB2135A0FBA">
      <dmn:requiredDecision href="#_49E05A4F-CF3C-4F0B-9CBF-B1ED840F70E5" />
    </dmn:informationRequirement>
    <dmn:literalExpression id="_C299A02E-ADD7-4515-B1D3-B2AF231714D5">
      <dmn:text>(monthlyExpenses + Monthly Payment Estimate) / (annualIncome / 12)</dmn:text>
    </dmn:literalExpression>
  </dmn:decision>
  <dmn:decision id="_4D630624-601F-4102-803C-9973C6601DF1" name="Loan to Value Ratio">
    <dmn:extensionElements />
    <dmn:variable id="_B7C8D362-F23D-451E-BD06-BBB9593DD976" name="Loan to Value Ratio" typeRef="number" />
    <dmn:informationRequirement id="_59231442-3396-4276-864C-14C0114DC244">
      <dmn:requiredInput href="#_FC133BE5-348C-48D8-8308-479456F905D6" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_F49C83C7-3BB6-410F-8987-BDCD20388193">
      <dmn:requiredInput href="#_792F25A0-FDEB-4AE9-B801-43FD945F16CF" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_65F1D87F-6921-4F13-9EC5-4C2AB4AD8D3C">
      <dmn:requiredInput href="#_8B9FB84A-48B1-4A83-A01F-F66D53D3B8EE" />
    </dmn:informationRequirement>
    <dmn:literalExpression id="_A79F1848-F7B4-4107-9E4E-43D6DF8D6CBE">
      <dmn:text>(loanAmount - downPayment) / propertyAppraisedValue</dmn:text>
    </dmn:literalExpression>
  </dmn:decision>
