        <dmn:outputEntry id="_858970EE-6BF9-4FD2-B105-C9C042A91597">
          <dmn:text>&quot;Loan-to-value ratio exceeds 95% threshold&quot;</dmn:text>
        </dmn:outputEntry>
        <dmn:annotationEntry>
          <dmn:text></dmn:text>
        </dmn:annotationEntry>
      </dmn:rule>
      <dmn:rule id="_533BA971-8DCD-4E5E-926D-5E85EFB7A99A">
        <dmn:inputEntry id="_EE98BBEE-BCE8-4B5F-AA43-3440EAA31293">
          <dmn:text>&gt;= 700</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="_D9A62095-CB85-4238-ACC7-B69CFDFEBB57">
