  </dmn:decision>
  <dmn:inputData id="_918F37F1-BDBA-4E5A-B0A2-50CC299A3EBF" name="CreditScore"><dmn:description>The applicant's credit score as a numeric value. Used to determine minimum creditworthiness. Applicants with a score below 600 are automatically ineligible.</dmn:description>
    <dmn:extensionElements/>
    <dmn:variable id="_1E96E75F-1F43-4777-9CD8-92968150F4EA" name="CreditScore" typeRef="number"/>
  </dmn:inputData>
  <dmn:inputData id="_32BD124A-6BCE-455B-90D6-44357B5412CA" name="LoanAmount"><dmn:description>The total loan amount requested by the applicant, expressed as a number in the same currency unit as AnnualIncome. Combined with AnnualIncome to compute the debt-to-income ratio used in eligibility evaluation.</dmn:description>
    <dmn:extensionElements/>
    <dmn:variable id="_99A8A42A-B35A-426B-8CBB-E205F6836645" name="LoanAmount" typeRef="number"/>
  </dmn:inputData>
  <dmn:inputData id="_109BEC55-D7B9-4658-BDCD-885F00485F9A" name="AnnualIncome"><dmn:description>The applicant's gross annual income, expressed as a number in the same currency unit as LoanAmount. Used as the denominator in the LoanAmount / AnnualIncome ratio. Must be greater than zero to avoid a division-by-zero evaluation error.</dmn:description>
    <dmn:extensionElements/>
    <dmn:variable id="_1E0D377E-DC99-4E93-9275-B34145358E98" name="AnnualIncome" typeRef="number"/>
  </dmn:inputData>
