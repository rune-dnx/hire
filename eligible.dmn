    </dmn:informationRequirement>
    <dmn:decisionTable id="_E52AABAB-17C2-4505-A5CC-5328A58A918C" hitPolicy="FIRST" preferredOrientation="Rule-as-Row" label="Eligible" typeRef="boolean">
      <dmn:input id="_EADEF2EE-8BB2-4800-82B9-1426804009BE">
        <dmn:inputExpression id="_B5D5B0E7-D90E-4E25-8E05-E6DD7D11C856" typeRef="number">
          <dmn:text>CreditScore</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:input id="_A04BF36E-CF18-4668-94B5-922E9286B614">
        <dmn:inputExpression id="_E5DA0AF5-77C1-4245-844E-4A0D4F4C2727" typeRef="number">
          <dmn:text>LoanAmount / AnnualIncome</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="_9277FDFF-5269-4730-9636-ACD74B49D869" name="eligible" typeRef="boolean"/>
      <dmn:annotation name="Annotations"/>
      <dmn:rule id="_AE881693-264A-4888-916C-CC989DE19944">
        <dmn:inputEntry id="_B99B96DF-0093-4AB7-ABA8-A9CC59D6DA88">
          <dmn:text>&lt; 600</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="_103B3857-8F25-4A7D-8A62-FE28C65EBEE4">
          <dmn:text>-</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="_8B286E48-D016-4EFA-B414-F2C6C47095C2">
          <dmn:text>false</dmn:text>
        </dmn:outputEntry>
        <dmn:annotationEntry>
          <dmn:text/>
        </dmn:annotationEntry>
      </dmn:rule>
      <dmn:rule id="_A6AD829C-D96E-41FA-B568-0012A3C55CB3">
        <dmn:inputEntry id="_EAF2321D-52B6-47D0-B858-E99361311B7A">
          <dmn:text>-</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="_DF4AAF7F-3510-458D-A692-486DAD023EB2">
          <dmn:text>&gt; 10</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="_6183CDE9-F919-485D-8064-A75DEE7504B6">
