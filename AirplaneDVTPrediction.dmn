  <dmn:decision id="_1eb45f4a-db35-4bcd-930e-2620ef67cf2a" name="FlightDecision">
    <dmn:description>## What it decides
Use this decision to produce the final flight recommendation based on overall DVT risk and intervention availability.
## Call when
- You need the final go/no-go travel advisory for the patient.
## Do not call when
- Only intermediate risk levels are needed without a recommendation.
## Inputs
- FlightRiskDVT (tFlightDetails) — combined DVT risk (High, Moderate, Low).
- EffectiveInterventionAvailable (boolean) — whether prophylactic treatment is accessible.
## Output
- `&quot;OK to go&quot;`: Low risk regardless of intervention, or High/Moderate with intervention available.
- `&quot;Modify plans&quot;`: Moderate risk without intervention.
- `&quot;Cancel flight&quot;`: High risk without intervention.
## Examples
- High risk, intervention=true → `&quot;OK to go&quot;`
- High risk, intervention=false → `&quot;Cancel flight&quot;`
- Moderate risk, intervention=false → `&quot;Modify plans&quot;`
- Low risk, intervention=false → `&quot;OK to go&quot;`</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_833de90f-40af-4438-84dc-23c5b39a39bc" name="FlightDecision" typeRef="tFlightDecision" />
    <dmn:informationRequirement id="_effde2cc-fafe-407a-8496-d2a6a11818db">
      <dmn:requiredDecision href="#_e6084413-3bf9-4e06-a2ba-6e2448289922" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_5ce43cda-643a-4437-972a-f43b31f058e6">
      <dmn:requiredInput href="#_a60fdfe0-8c86-46ba-b1b3-0133f81dc0a3" />
    </dmn:informationRequirement>
    <dmn:decisionTable id="_d2713d81-a8c8-409c-9b4a-87447e7d91f5" typeRef="tFlightDecision" hitPolicy="UNIQUE" preferredOrientation="Rule-as-Row" outputLabel="FlightDecision">
      <dmn:input id="_f146f888-e950-41dd-9a84-9f218be25dd0">
        <dmn:inputExpression id="_7BC8A305-C535-40F9-839C-49AC5F23827F" typeRef="tFlightDetails">
          <dmn:text>FlightRiskDVT</dmn:text>
        </dmn:inputExpression>
        <dmn:inputValues id="_A6E6CB08-A74A-4914-A5CF-244D12D91BF9">
          <dmn:text>&quot;High&quot;,&quot;Moderate&quot;,&quot;Low&quot;</dmn:text>
        </dmn:inputValues>
      </dmn:input>
      <dmn:input id="_991ee463-248f-4233-a1d0-0874de887270">
        <dmn:inputExpression id="_99297EC8-A5BE-45D7-86DC-5D11E2F3D33A" typeRef="boolean">
          <dmn:text>EffectiveInterventionAvailable</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="_ab22addf-2527-498b-bd0a-f28901609898">
        <dmn:outputValues id="_D5763D8F-8991-4D1C-9D01-39E356877E47">
          <dmn:text>&quot;Cancel flight&quot;,&quot;Modify plans&quot;,&quot;OK to go&quot;</dmn:text>
        </dmn:outputValues>
      </dmn:output>
      <dmn:annotation name="Description" />
