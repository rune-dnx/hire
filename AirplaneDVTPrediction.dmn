  <dmn:decision id="_2f8a702c-b8d9-4cce-83c4-a3e0f0b7071a" name="CalculateBMI">
    <dmn:description>## What it decides
Use this decision to compute the patient&apos;s Body Mass Index from height and weight.
## Call when
- You need BMI to evaluate obesity-related DVT risk.
## Do not call when
- BMI is already known or not relevant to the assessment.
## Inputs
- PatientBodyWeight (number, 0–500 kg) — body weight.
- PatientHeight (number, 0–3 m) — height.
## Output
- A number representing kg/m². Values &gt;30 indicate obesity.
## Examples
- 85 kg, 1.75 m → `27.76`
- 110 kg, 1.70 m → `38.06`</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_d1647615-1210-4592-ae81-24c7894e22c2" name="CalculateBMI" typeRef="number" />
    <dmn:informationRequirement id="_8edf73ae-e9d1-4472-b2c6-ad22d71c0ffe">
      <dmn:requiredInput href="#_cbc07ba3-711b-4f7b-a28c-e4138a8ed541" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_8d7f4de8-9b53-45db-9ef9-8845b604c0e9">
      <dmn:requiredInput href="#_f2e713eb-bce1-4c34-b38f-e9d51f51c77e" />
    </dmn:informationRequirement>
    <dmn:knowledgeRequirement id="_a21dadc8-3cbe-4e04-8ef3-4cdab6aa0987">
      <dmn:requiredKnowledge href="#_55c4467d-419c-460e-8e78-5a359d5a3998" />
    </dmn:knowledgeRequirement>
    <dmn:invocation id="_29ca9dd9-2990-49c4-8579-ffad89a3a916" typeRef="number">
      <dmn:literalExpression id="literal__29ca9dd9-2990-49c4-8579-ffad89a3a916">
        <dmn:text>BMIEquation</dmn:text>
      </dmn:literalExpression>
      <dmn:binding>
        <dmn:parameter id="_b83e2aa9-29e8-4d9e-8ea9-07326bb04945" name="BodyWeightkg" />
        <dmn:literalExpression id="_e2e6f32a-7b7e-4a61-99be-6cf281e9d3f8">
          <dmn:text>PatientBodyWeight</dmn:text>
        </dmn:literalExpression>
      </dmn:binding>
      <dmn:binding>
        <dmn:parameter id="_5da25b7f-5167-44b0-8c1e-1ab2ccd26310" name="BodyHeightMeters" />
        <dmn:literalExpression id="_0cda355b-1c08-4710-976d-5965287de002">
          <dmn:text>PatientHeight</dmn:text>
        </dmn:literalExpression>
      </dmn:binding>
    </dmn:invocation>
  </dmn:decision>
  <dmn:businessKnowledgeModel id="_55c4467d-419c-460e-8e78-5a359d5a3998" name="BMIEquation">
    <dmn:description>&lt;p&gt;To calculate the body mass index from the body weight in kilograms and height in meters.&lt;/p&gt;</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_cee3bbc5-bc77-4ca8-a12d-694440150dcb" name="BMIEquation" typeRef="number" />
    <dmn:encapsulatedLogic id="_3cb3092a-3f4d-4e64-86d2-eb1767d81c50" typeRef="number" kind="FEEL">
      <dmn:formalParameter id="_7073ddbc-42af-46ac-94ab-7e2c8d71bfd0" name="BodyWeightkg" typeRef="number" />
      <dmn:formalParameter id="_d658f387-b6db-461a-9528-523a148910b0" name="BodyHeightMeters" typeRef="number" />
      <dmn:literalExpression id="_609be1af-b8e1-4383-afc2-b8fe2766b97e" typeRef="number">
        <dmn:text>BodyWeightkg/(BodyHeightMeters**2)</dmn:text>
      </dmn:literalExpression>
    </dmn:encapsulatedLogic>
  </dmn:businessKnowledgeModel>
  <dmn:inputData id="_a9ff34b5-b702-4a81-be2e-19c716559ddb" name="LVEF">
    <dmn:description>Left Ventricular Ejection Fraction as a percentage (0–100). Measures heart pumping efficiency to assess congestive heart failure risk during flight. Required. Example values: 15 (severe), 35 (moderate), 60 (normal).</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_54398447-67b9-4c7d-9a02-f5eb5606c9d8" name="LVEF" typeRef="tLVEF" />
  </dmn:inputData>
  <dmn:inputData id="_a60fdfe0-8c86-46ba-b1b3-0133f81dc0a3" name="EffectiveInterventionAvailable">
    <dmn:description>Boolean flag indicating whether a clinically effective intervention (e.g. compression stockings, anticoagulant therapy) is available to mitigate DVT risk. Required. Example: true if patient has access to prophylactic measures.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_2ffc4595-d6c4-4114-9ef5-4d79de3eec60" name="EffectiveInterventionAvailable" typeRef="boolean" />
  </dmn:inputData>
  <dmn:inputData id="_fe1899a7-c9c4-4323-9f55-b83a9e4d1f5b" name="RecentAMI">
    <dmn:description>Boolean indicating whether the patient has experienced a recent Acute Myocardial Infarction (heart attack). A moderate DVT risk factor. Required. Example: true if AMI occurred within the last 6 weeks.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_f725814f-959e-4464-8b5c-e12a339c9546" name="RecentAMI" typeRef="boolean" />
  </dmn:inputData>
  <dmn:inputData id="_690fbdd5-b842-402c-a11e-0a08ef451170" name="HormoneTherapy">
    <dmn:description>Boolean indicating whether the patient is currently undergoing hormone replacement therapy or taking oral contraceptives. A moderate DVT risk factor. Required. Example: true if on estrogen therapy.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_f781433d-3490-41d2-bf2b-d7780c121a18" name="HormoneTherapy" typeRef="boolean" />
  </dmn:inputData>
  <dmn:inputData id="_33525201-af2f-4ea8-842b-906b1775faa7" name="IsPregnant">
    <dmn:description>Boolean indicating whether the patient is currently pregnant. Pregnancy is a moderate DVT risk factor due to increased blood coagulability. Required. Example: true or false.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_9dbf7eff-bd9a-4021-81da-d02b191b3c31" name="IsPregnant" typeRef="boolean" />
  </dmn:inputData>
  <dmn:inputData id="_3c733bc2-ccf9-4ca8-b61c-9b0d849d686e" name="Hypercoagulable">
    <dmn:description>Boolean indicating whether the patient has a known hypercoagulable (thrombophilia) disorder such as Factor V Leiden or Protein C deficiency. A high DVT risk factor. Required. Example: true if diagnosed.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_233aebb8-f673-48e8-bfab-5135e18492b0" name="Hypercoagulable" typeRef="boolean" />
  </dmn:inputData>
  <dmn:inputData id="_fece2cf8-7faf-4ea5-b871-be337b54d86b" name="RecentSurgery">
    <dmn:description>Boolean indicating whether the patient has had surgery recently (typically within the past 4–6 weeks). A high DVT risk factor due to immobility and tissue trauma. Required. Example: true if post-operative.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_48acf820-82f3-414f-abc4-c1ef9192bf75" name="RecentSurgery" typeRef="boolean" />
  </dmn:inputData>
  <dmn:inputData id="_ab93b4aa-d2aa-4416-93c5-374ac7b162e9" name="HasCancer">
    <dmn:description>Boolean indicating whether the patient has an active cancer diagnosis. Cancer is a high DVT risk factor due to its pro-coagulant effects. Required. Example: true if undergoing treatment.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_9500ef4e-ab1d-482a-a0e1-bc5a6788fb2e" name="HasCancer" typeRef="boolean" />
  </dmn:inputData>
  <dmn:inputData id="_cbc07ba3-711b-4f7b-a28c-e4138a8ed541" name="PatientHeight">
    <dmn:description>Patient&apos;s height in metres (0–3m). Used together with PatientBodyWeight to calculate BMI for obesity-related DVT risk assessment. Required. Example: 1.75.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_b03e044f-4c0d-47f1-b2b1-b6925a86a362" name="PatientHeight" typeRef="number" />
  </dmn:inputData>
  <dmn:inputData id="_f2e713eb-bce1-4c34-b38f-e9d51f51c77e" name="PatientBodyWeight">
    <dmn:description>Patient&apos;s body weight in kilograms (0–500 kg). Used with PatientHeight to compute BMI. A BMI above 30 is a moderate DVT risk factor. Required. Example: 85.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_6de36eb5-5a38-4eda-9ef9-fe752cd788b7" name="PatientBodyWeight" typeRef="number" />
  </dmn:inputData>
  <dmn:inputData id="_71c98ce3-2b98-4853-b6ca-741446aa4f67" name="FlightData">
    <dmn:description>Composite input containing flight Distance (km, &lt;30000) and Duration (hrs, 0–48). These values determine the inherent DVT risk of the flight itself. Required. Example: {Distance: 8500, Duration: 11}.</dmn:description>
    <dmn:extensionElements />
    <dmn:variable id="_e103358f-faa8-412a-8c49-d38d0df36784" name="FlightData" typeRef="tFlightData" />
  </dmn:inputData>
  <dmn:knowledgeSource id="_80bcf3b8-e4e5-424b-b051-f97d4e12c12c" name="Reference" locationURI="https://ncbi.nlm.nih.gov/pubmed/15541228">
    <dmn:description>&lt;p&gt;Possick SE, Barry M&lt;/p&gt;
&lt;p&gt;Air travel and cardiovascular disease.&lt;/p&gt;
&lt;p&gt;J Travel Medicine. 2004; 11(4): 243-248.&lt;/p&gt;</dmn:description>
    <dmn:extensionElements />
    <dmn:authorityRequirement id="_1b15f6b6-ef83-4fee-89c7-107bd117ca79">
      <dmn:requiredDecision href="#_1eb45f4a-db35-4bcd-930e-2620ef67cf2a" />
    </dmn:authorityRequirement>
    <dmn:type>Journal article</dmn:type>
  </dmn:knowledgeSource>
