  <dmn:decision id="_49E05A4F-CF3C-4F0B-9CBF-B1ED840F70E5" name="Monthly Payment Estimate">
    <dmn:extensionElements />
    <dmn:variable id="_DDABA657-F6D7-4534-9D12-83DDDD3E62AB" name="Monthly Payment Estimate" typeRef="number" />
    <dmn:informationRequirement id="_20C0928C-7291-4414-B5C4-5F59D8D131E8">
      <dmn:requiredInput href="#_FC133BE5-348C-48D8-8308-479456F905D6" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_3081D662-7A18-495D-9EDD-A6789A1FCAB2">
      <dmn:requiredInput href="#_792F25A0-FDEB-4AE9-B801-43FD945F16CF" />
    </dmn:informationRequirement>
    <dmn:literalExpression id="_6FA43A52-0BE2-4EB2-AF6A-C694E4FFFDF8">
      <dmn:text>(loanAmount - downPayment) * 0.006</dmn:text>
    </dmn:literalExpression>
  </dmn:decision>
