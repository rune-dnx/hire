    <dmn:informationRequirement id="_65F1D87F-6921-4F13-9EC5-4C2AB4AD8D3C">
      <dmn:requiredInput href="#_8B9FB84A-48B1-4A83-A01F-F66D53D3B8EE" />
    </dmn:informationRequirement>
    <dmn:literalExpression id="_A79F1848-F7B4-4107-9E4E-43D6DF8D6CBE">
      <dmn:text>(loanAmount - downPayment) / propertyAppraisedValue</dmn:text>
